# ═══════════════════════════════════════════════════════════════
# AI STOCK PLATFORM — Environment Variables
# ═══════════════════════════════════════════════════════════════
#
# DEVELOPMENT:
#   cp .env.example .env.local
#   # Fill in values for each service below.
#
# PRODUCTION (Vercel):
#   vercel env add <KEY> production
#   # Or add via: Vercel Dashboard → Settings → Environment Variables
#
# ═══════════════════════════════════════════════════════════════

# ────────────────────────────────────────────────────────────────
# DATABASE — Supabase PostgreSQL
# ────────────────────────────────────────────────────────────────
# Supabase Dashboard → Project → Settings → Database → Connection string
# Use Session mode (port 5432 pooler) for both URLs with Prisma.
#   Session pooler:    aws-0-...pooler.supabase.com:5432
#   Transaction pooler: aws-0-...pooler.supabase.com:6543
DATABASE_URL="postgresql://postgres.<project-ref>:<db-password>@aws-0-us-east-1.pooler.supabase.com:5432/postgres"
DIRECT_URL="postgresql://postgres.<project-ref>:<db-password>@aws-0-us-east-1.pooler.supabase.com:5432/postgres"

# ────────────────────────────────────────────────────────────────
# SUPABASE — Auth & API
# ────────────────────────────────────────────────────────────────
# Supabase Dashboard → Project → Settings → API
#   anon/public key → safe for client (RLS-scoped)
#   service_role key → server-only (NEVER prefix with NEXT_PUBLIC_)
NEXT_PUBLIC_SUPABASE_URL="https://<project-id>.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."
SUPABASE_SERVICE_ROLE_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."

# ────────────────────────────────────────────────────────────────
# AI — DeepSeek (primary)
# ────────────────────────────────────────────────────────────────
# https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY="sk-..."
# Model: deepseek-chat (fast) or deepseek-reasoner (R1, deep reasoning)
AI_MODEL="deepseek-chat"
AI_MAX_TOKENS="4096"
AI_TEMPERATURE="0.1"

# ────────────────────────────────────────────────────────────────
# AI — OpenAI (fallback / alternative)
# ────────────────────────────────────────────────────────────────
# https://platform.openai.com/api-keys
OPENAI_API_KEY="sk-..."
# ANTHROPIC_API_KEY="sk-ant-..."
# GOOGLE_GENERATIVE_AI_API_KEY="..."

# ────────────────────────────────────────────────────────────────
# STOCK DATA — Market APIs
# ────────────────────────────────────────────────────────────────
# Finnhub (primary — 60 calls/min free)
#   https://finnhub.io/dashboard
FINNHUB_API_KEY=""
# Alpha Vantage (fallback — 25 calls/day free)
#   https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=""
# Polygon.io (premium — real-time data)
#   https://polygon.io/dashboard
POLYGON_API_KEY=""
# Provider: "finnhub" | "alphavantage"
STOCK_PROVIDER="finnhub"

# ────────────────────────────────────────────────────────────────
# APP
# ────────────────────────────────────────────────────────────────
# Development
APP_URL="http://localhost:3000"
NODE_ENV="development"
# Production (set on Vercel):
# APP_URL="https://ai-stock-platform.vercel.app"
# NODE_ENV="production"

# ────────────────────────────────────────────────────────────────
# FEATURE FLAGS
# ────────────────────────────────────────────────────────────────
ENABLE_REALTIME_UPDATES="false"
ENABLE_BACKTESTING="false"

# ────────────────────────────────────────────────────────────────
# RATE LIMITING (Upstash Redis — production only)
# ────────────────────────────────────────────────────────────────
# UPSTASH_REDIS_URL="https://..."
# UPSTASH_REDIS_TOKEN="..."
