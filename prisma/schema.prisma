//   ON stock_cache USING gin (to_tsvector('english', name));
//
// CREATE INDEX idx_stock_cache_ticker_trgm
//   ON stock_cache USING gin (ticker gin_trgm_ops);
//   (requires: CREATE EXTENSION IF NOT EXISTS pg_trgm;)
//
